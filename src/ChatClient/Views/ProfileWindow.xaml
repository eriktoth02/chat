<Window x:Class="ChatClient.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit profile" Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E2E">
    <Border Padding="24">
        <StackPanel>
            <TextBlock Text="Edit profile" FontSize="20" FontWeight="Bold"
                       Foreground="White" Margin="0,0,0,16"/>

            <TextBlock Text="Display name" Foreground="#B0B0C0" Margin="0,0,0,4"/>
            <TextBox x:Name="DisplayNameBox" Height="32" Padding="8,6" Margin="0,0,0,4"/>
            <TextBlock Text="Shown to others instead of your username. Leave empty to use your username."
                       Foreground="#7A7A92" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,14"/>

            <TextBlock Text="New password" Foreground="#B0B0C0" Margin="0,0,0,4"/>
            <PasswordBox x:Name="NewPasswordBox" Height="32" Padding="8,6" Margin="0,0,0,4"/>
            <TextBlock Text="Leave empty to keep your current password."
                       Foreground="#7A7A92" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

            <TextBlock x:Name="StatusText" Foreground="#FF6B6B" TextWrapping="Wrap"
                       MinHeight="18" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Cancel" Width="100" Height="34"
                        Background="#3A3A4E" Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button x:Name="SaveButton" Content="Save" Width="100" Height="34"
                        IsDefault="True" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
