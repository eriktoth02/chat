<Window x:Class="ChatClient.Views.DirectChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ChatClient.ViewModels"
        Title="Direct message" Height="540" Width="460"
        WindowStartupLocation="CenterScreen" Background="#1E1E2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#181825" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Chat with " Foreground="#8888A0" FontSize="16" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding OtherName}" Foreground="White" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="Scroll" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10,8">
            <ItemsControl ItemsSource="{Binding Messages}">
                <ItemsControl.Resources>
                    <DataTemplate DataType="{x:Type vm:DmItem}">
                        <StackPanel HorizontalAlignment="{Binding Align}" Margin="6,4" MaxWidth="330">
                            <Border Background="{Binding BubbleBrush}" CornerRadius="10" Padding="10,6">
                                <TextBlock Text="{Binding Content}" Foreground="White"
                                           TextWrapping="Wrap" FontSize="14"/>
                            </Border>
                            <TextBlock Text="{Binding StatusText}" Visibility="{Binding StatusVisibility}"
                                       Foreground="#8888A0" FontSize="10"
                                       HorizontalAlignment="Right" Margin="0,1,4,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.Resources>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="10,8,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="Input" Grid.Column="0" Height="40" Padding="10,8"
                     VerticalContentAlignment="Center"
                     Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="Input_KeyDown"/>
            <Button Grid.Column="1" Content="Send" Width="84" Height="40" Margin="8,0,0,0"
                    Command="{Binding SendCommand}"/>
        </Grid>
    </Grid>
</Window>
