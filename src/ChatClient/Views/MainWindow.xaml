<Window x:Class="ChatClient.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ChatClient.ViewModels"
        Title="Chat" Height="620" Width="940"
        WindowStartupLocation="CenterScreen" Background="#1E1E2E">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== Sidebar ===== -->
        <Grid Grid.Column="0" Background="#181825">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#11111B" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="Signed in as" Foreground="#8888A0" FontSize="11"/>
                    <TextBlock Text="{Binding CurrentUsername}" Foreground="White"
                               FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="1" Text="ROOMS" Foreground="#8888A0"
                       FontSize="11" FontWeight="SemiBold" Margin="16,14,0,4"/>

            <ListBox Grid.Row="2" Margin="8,0" MaxHeight="220"
                     ItemsSource="{Binding Rooms}"
                     SelectedItem="{Binding SelectedRoom, Mode=TwoWay}"
                     DisplayMemberPath="Name"/>

            <Grid Grid.Row="3" Margin="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Height="30" VerticalContentAlignment="Center" Padding="8,0"
                         Text="{Binding NewRoomName, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="1" Content="+" Width="32" Height="30" Margin="6,0,0,0"
                        FontSize="18" Command="{Binding CreateRoomCommand}" ToolTip="Create room"/>
            </Grid>

            <TextBlock Grid.Row="4" Text="DIRECT MESSAGES" Foreground="#8888A0"
                       FontSize="11" FontWeight="SemiBold" Margin="16,12,0,4"/>

            <ListBox Grid.Row="5" x:Name="DmList" Margin="8,0" MaxHeight="170"
                     ItemsSource="{Binding DmUsers}" MouseDoubleClick="DmList_MouseDoubleClick"
                     ToolTip="Double-click a user to open a private chat">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <Border Grid.Column="1" Background="#894FD6" CornerRadius="9"
                                    MinWidth="18" Height="18"
                                    Visibility="{Binding HasUnread, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding Badge}" Foreground="White" FontSize="10"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,0"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Grid.Row="6" Text="ONLINE" Foreground="#8888A0"
                       FontSize="11" FontWeight="SemiBold" Margin="16,12,0,4"/>

            <ScrollViewer Grid.Row="7" MaxHeight="150" Margin="16,0"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding OnlineUsers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Ellipse Width="9" Height="9" Fill="#4ADE80" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding}" Foreground="#D0D0E0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Row 8 (*) is an empty spacer that pushes the buttons to the bottom -->

            <StackPanel Grid.Row="9" Margin="16,8,16,12">
                <Button Content="Edit profile" Height="32" Margin="0,0,0,8"
                        Background="#3A3A4E" Click="OpenProfile_Click"/>
                <Button Content="Log out" Height="32"
                        Background="#3A3A4E" Command="{Binding LogoutCommand}"/>
            </StackPanel>
        </Grid>

        <!-- ===== Chat area ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#181825" Padding="18,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding SelectedRoom.Name, FallbackValue='Select a room'}"
                               Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Status}" Foreground="#FF6B6B"
                               VerticalAlignment="Center" Margin="16,2,0,0"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <ScrollViewer x:Name="MessageScroll"
                              VerticalScrollBarVisibility="Auto" Padding="10,8"
                              ScrollChanged="MessageScroll_ScrollChanged">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.Resources>
                            <DataTemplate DataType="{x:Type vm:MessageItem}">
                                <Border HorizontalAlignment="{Binding Align}"
                                        Background="{Binding BubbleBrush}"
                                        CornerRadius="10" Padding="11,7" Margin="6,4" MaxWidth="540">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick"
                                                      Command="{Binding DataContext.EditMessageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Header}" Foreground="#D8D8E8"
                                                   FontSize="11" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding Content}" Foreground="White"
                                                   TextWrapping="Wrap" FontSize="14"
                                                   Visibility="{Binding HasText, Converter={StaticResource BoolToVis}}"/>
                                        <Image Source="{Binding AttachmentUrl}" MaxHeight="220" MaxWidth="320"
                                               Stretch="Uniform" Margin="0,4,0,0"
                                               Visibility="{Binding IsImage, Converter={StaticResource BoolToVis}}"/>
                                        <Button Content="{Binding AttachmentName}" Tag="{Binding AttachmentUrl}"
                                                Click="Attachment_Click" HorizontalAlignment="Left"
                                                Margin="0,4,0,0" Padding="10,5" Background="#3A3A4E"
                                                Visibility="{Binding IsFile, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:DateSeparator}">
                                <Border HorizontalAlignment="Center" Background="#2A2A3C"
                                        CornerRadius="9" Padding="12,3" Margin="0,10">
                                    <TextBlock Text="{Binding Text}" Foreground="#A0A0B8" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.Resources>
                    </ItemsControl>
                </ScrollViewer>

                <!-- "new messages" pill shown when scrolled up -->
                <Button x:Name="UnreadPill" Content="{Binding UnreadText}"
                        Visibility="{Binding HasUnread, Converter={StaticResource BoolToVis}}"
                        Click="UnreadPill_Click"
                        VerticalAlignment="Bottom" HorizontalAlignment="Center"
                        Margin="0,0,0,12" Padding="14,6" FontSize="12"/>
            </Grid>

            <TextBlock Grid.Row="2" Text="{Binding TypingIndicator}" Height="18"
                       Foreground="#9090A8" FontStyle="Italic" Margin="18,0,0,2"/>

            <!-- Emoji quick bar -->
            <ItemsControl Grid.Row="3" Margin="12,0,12,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <Button Content="😀" CommandParameter="😀" Command="{Binding InsertEmojiCommand}"
                        Background="Transparent" FontSize="18" Width="34" Height="30"/>
                <Button Content="😂" CommandParameter="😂" Command="{Binding InsertEmojiCommand}"
                        Background="Transparent" FontSize="18" Width="34" Height="30"/>
                <Button Content="👍" CommandParameter="👍" Command="{Binding InsertEmojiCommand}"
                        Background="Transparent" FontSize="18" Width="34" Height="30"/>
                <Button Content="❤️" CommandParameter="❤️" Command="{Binding InsertEmojiCommand}"
                        Background="Transparent" FontSize="18" Width="34" Height="30"/>
                <Button Content="🎉" CommandParameter="🎉" Command="{Binding InsertEmojiCommand}"
                        Background="Transparent" FontSize="18" Width="34" Height="30"/>
                <Button Content="🙏" CommandParameter="🙏" Command="{Binding InsertEmojiCommand}"
                        Background="Transparent" FontSize="18" Width="34" Height="30"/>
                <Button Content="😎" CommandParameter="😎" Command="{Binding InsertEmojiCommand}"
                        Background="Transparent" FontSize="18" Width="34" Height="30"/>
                <Button Content="😢" CommandParameter="😢" Command="{Binding InsertEmojiCommand}"
                        Background="Transparent" FontSize="18" Width="34" Height="30"/>
            </ItemsControl>

            <Grid Grid.Row="4" Margin="10,6,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="📎" Width="40" Height="40" Margin="0,0,8,0"
                        FontSize="16" Background="#3A3A4E" Click="Attach_Click" ToolTip="Attach a file"/>
                <TextBox x:Name="MessageInput" Grid.Column="1" Height="40"
                         Padding="10,8" VerticalContentAlignment="Center"
                         Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="MessageInput_KeyDown"/>
                <Button Grid.Column="2" Content="✕" Width="40" Height="40" Margin="8,0,0,0"
                        Background="#3A3A4E" Command="{Binding CancelEditCommand}" ToolTip="Cancel edit"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                <Button Grid.Column="3" Content="{Binding SendButtonText}" Width="92" Height="40" Margin="8,0,0,0"
                        Command="{Binding SendCommand}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
