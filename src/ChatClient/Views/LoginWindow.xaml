<Window x:Class="ChatClient.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat - Sign in" Width="380" SizeToContent="Height" MinHeight="360"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="#1E1E2E">
    <Border Padding="28">
        <StackPanel>
            <TextBlock Text="Chat" FontSize="30" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="real-time chat" FontSize="12"
                       Foreground="#8888A0" HorizontalAlignment="Center" Margin="0,0,0,22"/>

            <TextBlock Text="Username" Foreground="#B0B0C0" Margin="0,0,0,4"/>
            <TextBox x:Name="UsernameBox" Height="32" Padding="8,6" Margin="0,0,0,12"/>

            <TextBlock Text="Password" Foreground="#B0B0C0" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordBox" Height="32" Padding="8,6" Margin="0,0,0,8"/>

            <TextBlock x:Name="StatusText" Foreground="#FF6B6B" TextWrapping="Wrap"
                       MinHeight="18" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="LoginButton" Content="Log in" Width="120" Height="36"
                        Margin="0,0,8,0" IsDefault="True" Click="Login_Click"/>
                <Button x:Name="RegisterButton" Content="Register" Width="120" Height="36"
                        Background="#3A3A4E" Click="Register_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
